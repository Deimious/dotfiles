            case "[blue]":  value = "[U]"; break;
            case "[black]": value = "[B]"; break;
            case "[red]":   value = "[R]"; break;
            case "[green]": value = "[G]"; break;
            case "[colorless]": value = "[C]"; break;
            case '["white"]': value = "[W]"; break;
            case '["blue"]': value = "[U]"; break;
            case '["black"]': value = "[B]"; break;
            case '["red"]': value = "[R]"; break;
            case '["green"]': value = "[G]"; break;
            case '["colorless"]': value = "[C]"; break;
