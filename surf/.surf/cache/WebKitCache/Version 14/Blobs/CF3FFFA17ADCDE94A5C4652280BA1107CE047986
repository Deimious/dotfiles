function TranslateTermFromSerialized(fromKey, value, includeBrackets) {
    value = value.replace(/\[/, "").replace(/\]/, ""); // remove enclosers for display

    if (includeBrackets) {
        value = value.replace(/►/g, "[").replace(/◄/g, "]"); // remove inner brackets put in by users
    }    

    switch(fromKey)
    {
        case "color":
            {
                switch(value)
                {
                    case "W": value = "White"; break;
                    case "U": value = "Blue"; break;
