{
    "brackets-eslint.gutterMarks": true,
    "brackets-eslint.useLocalESLint": false,
    "fonts.fontSize": "12px",
    "fonts.fontFamily": "Consolas, 'xos4 Terminus', 'SourceCodePro-Medium', monospace",
    "livedev.multibrowser": true,
    "healthData.healthDataTracking": false,
    "extensions.sort": "downloadCount",
    "themes.theme": "nickprough.kracken",
    "noDistractions": true,
    "styleActiveLine": false,
    "showLineNumbers": true,
    "useTabChar": true,
    "tabSize": 5,
    "linting.JSLint.collapsed": false,
    "linting.collapsed": true,
    "extensions.default.disabled": [
        "/opt/brackets/www/extensions/default/brackets-eslint",
        "/opt/brackets/www/extensions/default/JSLint"
    ]
}